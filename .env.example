# project-agent-system — environment variables.
#
# Copy this file to .env and fill in real values. Required keys cause
# `docker compose up` to fail-fast at parse time per REQ-MNT-env-driven-config.
#
# This file IS committed; .env is gitignored. Generate auth tokens with:
#   openssl rand -hex 32        # 64-char hex, ≥256 bits of entropy from CSPRNG
#
# Drift between this file and `docker-compose.yml` is detected by
# `scripts/check-env-drift.sh` (run by CI on every PR).

# =====================================================================
# Compose profile selection (REQ-MNT-env-driven-config)
# =====================================================================

# Ingress profile. Set to either "caddy" (public hostname, default) or
# "tailscale" (private-network-only). REQUIRED.
COMPOSE_PROFILES=caddy

# =====================================================================
# Postgres (DEC-postgres-as-event-store)
# =====================================================================

# Database name. Optional; defaults to "vision" inside compose.
POSTGRES_DB=vision

# Database user. Optional; defaults to "vision" inside compose.
POSTGRES_USER=vision

# Database password. REQUIRED — `docker compose up` fails fast if missing.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# =====================================================================
# Caddy ingress (only used when COMPOSE_PROFILES=caddy)
# =====================================================================

# HTTP port (operator-facing). Optional (caddy profile); defaults to 80.
CADDY_HTTP_PORT=80

# HTTPS port (operator-facing). Optional (caddy profile); defaults to 443.
CADDY_HTTPS_PORT=443

# =====================================================================
# Tailscale ingress (only used when COMPOSE_PROFILES=tailscale)
# =====================================================================

# Tailscale auth key. REQUIRED only when COMPOSE_PROFILES=tailscale (ignored otherwise).
# Get from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Tailscale hostname for this node. Optional (tailscale profile); defaults to "vision".
TS_HOSTNAME=vision

# =====================================================================
# Service auth tokens (DEC-service-auth-bearer-tokens)
# =====================================================================
# One token per calling service identity, opaque random ≥256 bits.
# Generate each with: openssl rand -hex 32
#
# Each token is REQUIRED — `docker compose config` fails fast if any is empty.
#
# Token model: every service's outbound HTTP carries ITS OWN token.
# Receiving services check the inbound token against their accepted-tokens
# list, mapped to the calling identity name (used for audit attribution
# per REQ-SEC-audit-log).
#
# Rotate per REQ-REL-secret-rotation. Rotation runbook will live in
# `4-deploy/runbooks/secret-rotation.md` (added by TASK-secret-rotation-runbook).

# whatsorga-ingest's identity. Accepted by backlog-core for inbound
# POST /v1/inputs requests. Generate: `openssl rand -hex 32`.
WHATSORGA_INGEST_TOKEN=

# hermes-runtime's identity. Accepted by backlog-core, gbrain-bridge,
# and kanban-sync for proposal-pipeline calls and reads.
HERMES_RUNTIME_TOKEN=

# backlog-core's identity. Accepted by gbrain-bridge and kanban-sync for
# RTBF cascade and proposal-applied notifications.
BACKLOG_CORE_TOKEN=

# gbrain-bridge's identity. Accepted by backlog-core for outbound
# disposition POSTs from the Obsidian command-palette watch script
# (per DEC-obsidian-as-review-ui).
GBRAIN_BRIDGE_TOKEN=

# kanban-sync's identity. Accepted by backlog-core for outbound
# `kanban.user_edit` and `unattributed_edit` events.
KANBAN_SYNC_TOKEN=

# Operator (CLI) identity. Accepted by ALL services for operator
# CLI commands and the cli component's reads.
OPERATOR_TOKEN=
